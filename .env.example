# ─── AceStream Orchestrator — Environment Variables ───────────────────────────
# Copy this file to .env and edit the values before starting the stack.
# Recommended startup: docker-compose.yml with orchestrator-managed VPN provisioning.
# Legacy docker-compose.gluetun*.yml files are deprecated.
#
# Settings marked [UI] can also be changed at runtime via the Settings dashboard
# and will be persisted to app/config/*.json.  The env var takes effect on
# container start; the UI value overrides it after the first save.
# ──────────────────────────────────────────────────────────────────────────────


# ─── Security ─────────────────────────────────────────────────────────────────
# API key required for all protected endpoints (see docs/API.md).
# Authentication: Authorization: Bearer <API_KEY>
# Leave empty to disable authentication (not recommended for production).
API_KEY=


# ─── Engine Lifecycle ─────────────────────────────────────────────────────────
# Minimum number of engine containers kept running at all times.           [UI]
MIN_REPLICAS=2

# Minimum number of idle (unassigned) engines to maintain.                 [UI]
MIN_FREE_REPLICAS=1

# Maximum number of engine containers allowed to run simultaneously.       [UI]
MAX_REPLICAS=6

# Seconds to wait for a new engine to become healthy before giving up.     [UI]
STARTUP_TIMEOUT_S=25

# Seconds an idle engine is kept alive before being terminated.            [UI]
IDLE_TTL_S=600

# Seconds after the last stream ends before stopping an engine.            [UI]
ENGINE_GRACE_PERIOD_S=30

# Seconds between autoscaler evaluation cycles.                            [UI]
AUTOSCALE_INTERVAL_S=30

# Maximum streams routed to a single engine at the same time.              [UI]
MAX_STREAMS_PER_ENGINE=3

# Maximum number of engines that can be provisioned concurrently.
MAX_CONCURRENT_PROVISIONS=5

# Minimum seconds between consecutive provision requests.
MIN_PROVISION_INTERVAL_S=0.5


# ─── Engine Image / Variant ───────────────────────────────────────────────────
# Built-in variant name.  Auto-detected from host architecture if unset.
# Options: AceServe-amd64 | AceServe-arm32 | AceServe-arm64 | krinkuto11-amd64
ENGINE_VARIANT=AceServe-amd64

# ARM image tag versions (used by AceServe-arm32 / AceServe-arm64 variants).
ENGINE_ARM32_VERSION=arm32-v3.2.13
ENGINE_ARM64_VERSION=arm64-v3.2.13

# Optional memory limit applied to every engine container (e.g. "512m", "2g").
#ENGINE_MEMORY_LIMIT=


# ─── Port Ranges ──────────────────────────────────────────────────────────────
# Host-side port range allocated to engine containers.                     [UI]
# Must match the port mapping published by the Gluetun containers.
PORT_RANGE_HOST=19000-19999

# Internal AceStream HTTP port range (container side).                     [UI]
ACE_HTTP_RANGE=40000-44999

# Internal AceStream HTTPS port range (container side).                    [UI]
ACE_HTTPS_RANGE=45000-49999

# Set to true to also expose the HTTPS port on the host.
ACE_MAP_HTTPS=false


# ─── VPN (Gluetun) ────────────────────────────────────────────────────────────
# Enable orchestrator-managed dynamic VPN node provisioning.                [UI]
DYNAMIC_VPN_MANAGEMENT=true

# Default VPN provider/protocol for dynamic nodes.                         [UI]
VPN_PROVIDER=protonvpn
VPN_PROTOCOL=wireguard

# Target engine density per dynamic VPN node.                              [UI]
PREFERRED_ENGINES_PER_VPN=10

# Deprecated static fallback: bind to a pre-existing Gluetun container.
# Prefer dynamic provisioning instead.
#GLUETUN_CONTAINER_NAME=gluetun

# Internal API port used to contact Gluetun control server from Docker network. [UI]
GLUETUN_API_PORT=8001

# How often (seconds) to poll Gluetun health.                              [UI]
GLUETUN_HEALTH_CHECK_INTERVAL_S=5

# How long (seconds) to cache the forwarded port value from Gluetun.       [UI]
GLUETUN_PORT_CACHE_TTL_S=60

# Restart VPN-attached engines when the VPN reconnects.                    [UI]
VPN_RESTART_ENGINES_ON_RECONNECT=true

# Seconds of continuous VPN unhealthiness before force-restarting it.      [UI]
VPN_UNHEALTHY_RESTART_TIMEOUT_S=60

# Startup grace (seconds) before healing NotReady dynamic VPN nodes.
# Helps avoid destroy/recreate churn while Gluetun initializes.
VPN_NOTREADY_HEAL_GRACE_S=45

# Host port sub-ranges for multi-VPN distribution (legacy/static + dynamic modes).
#GLUETUN_PORT_RANGE_1=19000-19499
#GLUETUN_PORT_RANGE_2=19500-19999


# ─── Health Monitoring ────────────────────────────────────────────────────────
# Seconds between engine health checks.                                    [UI]
HEALTH_CHECK_INTERVAL_S=20

# Consecutive failures before marking an engine unhealthy.                 [UI]
HEALTH_FAILURE_THRESHOLD=3

# Seconds an unhealthy engine is tolerated before replacement is triggered. [UI]
HEALTH_UNHEALTHY_GRACE_PERIOD_S=60

# Minimum seconds between engine replacement attempts.                     [UI]
HEALTH_REPLACEMENT_COOLDOWN_S=60


# ─── Circuit Breaker ──────────────────────────────────────────────────────────
# Provisioning failures before the circuit breaker opens.                  [UI]
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5

# Seconds before a tripped circuit breaker attempts recovery.              [UI]
CIRCUIT_BREAKER_RECOVERY_TIMEOUT_S=300

# Replacement failures before the replacement circuit breaker opens.       [UI]
CIRCUIT_BREAKER_REPLACEMENT_THRESHOLD=3

# Seconds before a tripped replacement circuit breaker attempts recovery.  [UI]
CIRCUIT_BREAKER_REPLACEMENT_TIMEOUT_S=180


# ─── Statistics & Metrics ─────────────────────────────────────────────────────
# Seconds between stats collection cycles.
COLLECT_INTERVAL_S=1

# Maximum in-memory stats samples retained per engine.
STATS_HISTORY_MAX=720

# Default dashboard time window in seconds.
DASHBOARD_DEFAULT_WINDOW_S=900

# Seconds between dashboard metric persistence flushes.
DASHBOARD_PERSIST_INTERVAL_S=5

# Hours to retain dashboard metric history in the database.
DASHBOARD_METRICS_RETENTION_HOURS=168

# Number of concurrent workers for LEGACY_API stats probing.
LEGACY_STATS_PROBE_WORKERS=8


# ─── Stream Loop Detection ────────────────────────────────────────────────────
# Enable stale-stream (loop) detection.                                    [UI]
STREAM_LOOP_DETECTION_ENABLED=false

# Seconds of inactivity on live_last before a stream is considered stale.  [UI]
STREAM_LOOP_DETECTION_THRESHOLD_S=3600

# Seconds between loop-detection scan cycles.                              [UI]
STREAM_LOOP_CHECK_INTERVAL_S=10

# Minutes to retain detected loop IDs in memory (0 = indefinite).         [UI]
STREAM_LOOP_RETENTION_MINUTES=0


# ─── Proxy ────────────────────────────────────────────────────────────────────
# Initial stream delivery mode: TS (MPEG-TS) or HLS.                      [UI]
PROXY_STREAM_MODE=TS

# Stream control path: LEGACY_HTTP or LEGACY_API.                         [UI]
# Note: HLS requires LEGACY_HTTP; LEGACY_API requires TS.
PROXY_CONTROL_MODE=LEGACY_HTTP

# Preflight diagnostic depth: light (resolve only) or deep (resolve+probe). [UI]
PROXY_LEGACY_API_PREFLIGHT_TIER=light

# Connection and streaming timeouts (seconds).
PROXY_CONNECTION_TIMEOUT=10
PROXY_CLIENT_WAIT_TIMEOUT=30
PROXY_STREAM_TIMEOUT=60
PROXY_CHUNK_TIMEOUT=5

# Buffer and chunk sizes (bytes).
PROXY_INITIAL_BEHIND_CHUNKS=4
PROXY_CHUNK_SIZE=8192
#PROXY_BUFFER_CHUNK_SIZE=1061072   # ~1 MB default

# Retry behaviour.
PROXY_MAX_RETRIES=3
PROXY_RETRY_WAIT_INTERVAL=0.5

# Proxy health check interval (seconds).
PROXY_HEALTH_CHECK_INTERVAL=5

# Seconds before a client with no activity is considered a ghost.
PROXY_GHOST_CLIENT_MULTIPLIER=5.0

# Seconds to wait for initial data from an engine before failing.
PROXY_INITIAL_DATA_WAIT_TIMEOUT=10

# No-data detection: checks × interval = window (e.g. 60 × 1s = 60s).
PROXY_NO_DATA_TIMEOUT_CHECKS=60
PROXY_NO_DATA_CHECK_INTERVAL=1.0

# Grace periods (seconds).
PROXY_GRACE_PERIOD=5
PROXY_INIT_TIMEOUT=30

# Housekeeping intervals (seconds).
PROXY_CLEANUP_INTERVAL=60
PROXY_CLEANUP_CHECK_INTERVAL=3
PROXY_HEARTBEAT_INTERVAL=10
PROXY_KEEPALIVE_INTERVAL=0.5

# TTLs (seconds) for proxy client and buffer records.
PROXY_CLIENT_TTL=60
PROXY_BUFFER_TTL=60

# API-mode HLS client stale timeout (seconds).
# Controls how quickly disconnected API-HLS clients disappear from /proxy/streams/{key}/clients.
# Defaults to min(PROXY_CLIENT_TTL, 10) when not set.
API_HLS_CLIENT_TTL=10


# ─── Application ──────────────────────────────────────────────────────────────
# Port the orchestrator API listens on inside the container.
APP_PORT=8000

# Optional Docker network to attach engine containers to.
#DOCKER_NETWORK=

# Docker label applied to managed engine containers (key=value).
CONTAINER_LABEL=ondemand.app=myservice

# SQLAlchemy database URL.
DB_URL=sqlite:///./orchestrator.db

# Delete idle engines automatically when IDLE_TTL_S elapses.
AUTO_DELETE=true

# Seconds to wait for M3U playlist fetch.
M3U_TIMEOUT=15

# Enable verbose debug logging.
DEBUG_MODE=false

# Docker monitoring poll interval (seconds).
MONITOR_INTERVAL_S=10
